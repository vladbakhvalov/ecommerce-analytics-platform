  create  table "shopflow"."marts"."dim_date__dbt_tmp"
  
  
    as
  
  (
    -- Dimension: Date (from raw.dim_date, unchanged)

SELECT
    date_key,
    full_date,
    day_of_week,
    TRIM(day_name) AS day_name,
    day_of_month,
