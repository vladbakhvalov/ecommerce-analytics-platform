    year || '-' || LPAD(month_number::TEXT, 2, '0') AS year_month,
    CASE WHEN is_weekend OR is_holiday_de THEN TRUE ELSE FALSE END AS is_non_working_day

FROM "shopflow"."raw"."dim_date"
  );
  
