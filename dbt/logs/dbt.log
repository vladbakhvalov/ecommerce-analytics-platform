  create  table "shopflow"."staging_marts"."fct_orders__dbt_tmp"
  
  
    as
  
  (
    -- Fact: Orders (granularity: one row = one order item)

WITH orders AS (
    SELECT * FROM "shopflow"."staging_staging"."stg_orders"
),

items AS (
    SELECT * FROM "shopflow"."staging_staging"."stg_order_items"
),

products AS (
    SELECT product_id, cost FROM "shopflow"."raw"."products"
)

SELECT
    i.order_item_id,
    o.order_id,
    o.user_id,
    i.product_id,
    o.campaign_id,
    
    -- Date keys
    TO_CHAR(o.order_date_day, 'YYYYMMDD')::INTEGER AS order_date_key,
    o.order_date,
    o.order_date_day,
    
    -- Order info
    o.status,
    o.payment_method,
    o.shipping_country,
    
    -- Item metrics
    i.quantity,
    i.unit_price,
    i.discount_pct,
    i.line_revenue,
    
    -- Cost & margin
    p.cost AS unit_cost,
    i.quantity * p.cost AS line_cost,
    i.line_revenue - (i.quantity * p.cost) AS line_profit,
    
    -- Flags
    CASE WHEN o.status = 'refunded' THEN TRUE ELSE FALSE END AS is_refunded,
    CASE WHEN o.campaign_id IS NOT NULL THEN TRUE ELSE FALSE END AS is_from_campaign

FROM orders o
JOIN items i ON o.order_id = i.order_id
LEFT JOIN products p ON i.product_id = p.product_id
  );
  
[0m01:28:42.564562 [debug] [Thread-1 (]: On model.shopflow.int_daily_revenue: /* {"app": "dbt", "dbt_version": "1.9.0", "profile_name": "shopflow", "target_name": "dev", "node_id": "model.shopflow.int_daily_revenue"} */

  create view "shopflow"."staging_intermediate"."int_daily_revenue__dbt_tmp"
    
    
  as (
    -- Intermediate: daily revenue
-- Used for Executive Summary and trends

WITH orders AS (
    SELECT * FROM "shopflow"."staging_staging"."stg_orders"
),

items AS (
    SELECT * FROM "shopflow"."staging_staging"."stg_order_items"
)

SELECT
    o.order_date_day AS revenue_date,
    COUNT(DISTINCT o.order_id) AS total_orders,
    COUNT(DISTINCT o.user_id) AS unique_customers,
    SUM(i.line_revenue) AS total_revenue,
    SUM(i.line_revenue) / NULLIF(COUNT(DISTINCT o.order_id), 0) AS avg_order_value,
    SUM(i.quantity) AS total_units_sold
FROM orders o
JOIN items i ON o.order_id = i.order_id
GROUP BY o.order_date_day
  );
