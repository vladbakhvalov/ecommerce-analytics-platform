  create  table "shopflow"."marts"."dim_campaigns__dbt_tmp"
  
  
    as
  
  (
    -- Dimension: Advertising Campaigns

SELECT
    campaign_id,
    campaign_name,
    channel,
    campaign_type,
    start_date,
    end_date,
    daily_budget,
    is_active,
    COALESCE(end_date, CURRENT_DATE) - start_date AS campaign_duration_days

FROM "shopflow"."staging"."stg_campaigns"
  );
  
[0m02:26:47.720065 [debug] [Thread-1 (]: SQL status: BEGIN in 0.011 seconds
