  create  table "shopflow"."staging_reports"."rpt_conversion_funnel__dbt_tmp"
  
  
    as
  
  (
    -- Report: Conversion Funnel by Day
-- page_view → product_view → add_to_cart → begin_checkout → purchase

WITH daily_events AS (
    SELECT
        event_date,
        device_type,
        event_type,
        COUNT(DISTINCT session_id) AS unique_sessions,
        COUNT(DISTINCT user_id) AS unique_users
    FROM "shopflow"."staging_marts"."fct_events"
    WHERE funnel_step > 0
    GROUP BY event_date, device_type, event_type
),

pivoted AS (
    SELECT
        event_date,
        device_type,
        
        SUM(CASE WHEN event_type = 'page_view' THEN unique_sessions ELSE 0 END) AS page_views,
        SUM(CASE WHEN event_type = 'product_view' THEN unique_sessions ELSE 0 END) AS product_views,
        SUM(CASE WHEN event_type = 'add_to_cart' THEN unique_sessions ELSE 0 END) AS add_to_carts,
        SUM(CASE WHEN event_type = 'begin_checkout' THEN unique_sessions ELSE 0 END) AS checkouts,
        SUM(CASE WHEN event_type = 'purchase' THEN unique_sessions ELSE 0 END) AS purchases
        
    FROM daily_events
    GROUP BY event_date, device_type
)

SELECT
    event_date,
    device_type,
    page_views,
    product_views,
    add_to_carts,
    checkouts,
    purchases,
    
    -- Conversion rates (%)
    ROUND(product_views::NUMERIC / NULLIF(page_views, 0) * 100, 2) AS cvr_view_to_product,
    ROUND(add_to_carts::NUMERIC / NULLIF(product_views, 0) * 100, 2) AS cvr_product_to_cart,
    ROUND(checkouts::NUMERIC / NULLIF(add_to_carts, 0) * 100, 2) AS cvr_cart_to_checkout,
    ROUND(purchases::NUMERIC / NULLIF(checkouts, 0) * 100, 2) AS cvr_checkout_to_purchase,
    ROUND(purchases::NUMERIC / NULLIF(page_views, 0) * 100, 2) AS cvr_overall

FROM pivoted
ORDER BY event_date, device_type
  );
  
