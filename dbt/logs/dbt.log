[0m01:31:38.227922 [debug] [Thread-2 (]: On model.shopflow.rpt_conversion_funnel: /* {"app": "dbt", "dbt_version": "1.9.0", "profile_name": "shopflow", "target_name": "dev", "node_id": "model.shopflow.rpt_conversion_funnel"} */

  
    

  create  table "shopflow"."staging_reports"."rpt_conversion_funnel__dbt_tmp"
  
  
    as
  
  (
    -- Report: Conversion Funnel by Day
-- page_view → product_view → add_to_cart → begin_checkout → purchase

WITH daily_events AS (
    SELECT
        event_date,
        device_type,
        event_type,
        COUNT(DISTINCT session_id) AS unique_sessions,
        COUNT(DISTINCT user_id) AS unique_users
    FROM "shopflow"."staging_marts"."fct_events"
    WHERE funnel_step > 0
    GROUP BY event_date, device_type, event_type
),

pivoted AS (
    SELECT
        event_date,
        device_type,
        
        SUM(CASE WHEN event_type = 'page_view' THEN unique_sessions ELSE 0 END) AS page_views,
        SUM(CASE WHEN event_type = 'product_view' THEN unique_sessions ELSE 0 END) AS product_views,
        SUM(CASE WHEN event_type = 'add_to_cart' THEN unique_sessions ELSE 0 END) AS add_to_carts,
        SUM(CASE WHEN event_type = 'begin_checkout' THEN unique_sessions ELSE 0 END) AS checkouts,
        SUM(CASE WHEN event_type = 'purchase' THEN unique_sessions ELSE 0 END) AS purchases
        
    FROM daily_events
    GROUP BY event_date, device_type
)

SELECT
    event_date,
    device_type,
    page_views,
    product_views,
    add_to_carts,
    checkouts,
    purchases,
    
    -- Conversion rates (%)
    ROUND(product_views::NUMERIC / NULLIF(page_views, 0) * 100, 2) AS cvr_view_to_product,
    ROUND(add_to_carts::NUMERIC / NULLIF(product_views, 0) * 100, 2) AS cvr_product_to_cart,
    ROUND(checkouts::NUMERIC / NULLIF(add_to_carts, 0) * 100, 2) AS cvr_cart_to_checkout,
    ROUND(purchases::NUMERIC / NULLIF(checkouts, 0) * 100, 2) AS cvr_checkout_to_purchase,
    ROUND(purchases::NUMERIC / NULLIF(page_views, 0) * 100, 2) AS cvr_overall

FROM pivoted
ORDER BY event_date, device_type
  );
  
[0m01:31:38.228937 [debug] [Thread-4 (]: SQL status: BEGIN in 0.018 seconds
[0m01:31:38.229434 [debug] [Thread-4 (]: Using postgres connection "model.shopflow.fct_orders"
[0m01:31:38.229908 [debug] [Thread-4 (]: On model.shopflow.fct_orders: /* {"app": "dbt", "dbt_version": "1.9.0", "profile_name": "shopflow", "target_name": "dev", "node_id": "model.shopflow.fct_orders"} */

  
    

  create  table "shopflow"."staging_marts"."fct_orders__dbt_tmp"
  
  
    as
  
  (
    -- Fact: Orders (granularity: one row = one order item)

WITH orders AS (
    SELECT * FROM "shopflow"."staging_staging"."stg_orders"
),

items AS (
    SELECT * FROM "shopflow"."staging_staging"."stg_order_items"
),

products AS (
    SELECT product_id, cost FROM "shopflow"."raw"."products"
)

SELECT
    i.order_item_id,
    o.order_id,
    o.user_id,
    i.product_id,
    o.campaign_id,
    
    -- Date keys
    TO_CHAR(o.order_date_day, 'YYYYMMDD')::INTEGER AS order_date_key,
    o.order_date,
    o.order_date_day,
    
    -- Order info
    o.status,
    o.payment_method,
    o.shipping_country,
    
    -- Item metrics
    i.quantity,
    i.unit_price,
    i.discount_pct,
    i.line_revenue,
    
    -- Cost & margin
    p.cost AS unit_cost,
    i.quantity * p.cost AS line_cost,
    i.line_revenue - (i.quantity * p.cost) AS line_profit,
    
    -- Flags
    CASE WHEN o.status = 'refunded' THEN TRUE ELSE FALSE END AS is_refunded,
    CASE WHEN o.campaign_id IS NOT NULL THEN TRUE ELSE FALSE END AS is_from_campaign

FROM orders o
JOIN items i ON o.order_id = i.order_id
LEFT JOIN products p ON i.product_id = p.product_id
  );
  
